# ==============================================
# SYNTHEX — Environment Variables Template
# Copy to .env and fill in values
# NEVER commit .env to git
# ==============================================

# --- Node ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# --- Database (PostgreSQL 16 + pgvector) ---
DATABASE_URL=postgresql://synthex_app:your_password_here@localhost:5432/synthex

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# --- JWT Secrets (min 32 chars each — generate with: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=generate_with_openssl_rand_hex_32_here_minimum_32chars
JWT_REFRESH_SECRET=generate_with_openssl_rand_hex_32_here_minimum_32chars

# --- Encryption key for CMS credentials (exactly 64 hex chars = 32 bytes) ---
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32_gives_64_char_string_00000000

# --- AI Worker ---
AI_WORKER_URL=http://localhost:8000
AI_WORKER_SECRET=generate_with_openssl_rand_hex_8

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- AWS (for production) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
ECR_REGISTRY=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Rate limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

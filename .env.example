# ==============================================
# Orffia Ads — Variáveis de Ambiente
# ==============================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores abaixo
# 3. NUNCA commite .env no git (já está no .gitignore)
# ==============================================

# ====================
# AMBIENTE
# ====================
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ====================
# DATABASE — PostgreSQL 15
# ====================
# PROD: postgresql://evolution:evolution123@172.17.0.1:5432/orffia_ads
# DEV:  postgresql://evolution:evolution123@localhost:5432/orffia_ads
DATABASE_URL=postgresql://evolution:evolution123@172.17.0.1:5432/orffia_ads

# ====================
# REDIS
# ====================
REDIS_URL=redis://:SENHA_REDIS@redis:6379/0
REDIS_PASSWORD=TROQUE_ESTA_SENHA_REDIS

# ====================
# SEGURANÇA — JWT & CRIPTOGRAFIA
# ====================
# Gerar: openssl rand -hex 32
JWT_ACCESS_SECRET=GERE_COM_OPENSSL_RAND_HEX_32_SUBSTITUA_ESTE_VALOR
JWT_REFRESH_SECRET=GERE_COM_OPENSSL_RAND_HEX_32_OUTRO_VALOR_DIFERENTE
# Gerar: openssl rand -hex 32 (exatamente 64 chars hex = 32 bytes)
ENCRYPTION_KEY=GERE_COM_OPENSSL_RAND_HEX_32_PARA_CREDENCIAIS_AES256

# ====================
# AI WORKER (Agente de qualificação — futuro)
# ====================
AI_WORKER_URL=http://ai-worker:8000
AI_WORKER_SECRET=GERE_COM_OPENSSL_RAND_HEX_16
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXX
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# ====================
# INTEGRAÇÕES — PLATAFORMAS DE ADS
# ====================
# Meta CAPI (Conversions API)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Google Ads (Enhanced Conversions / Offline Conversion Import)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# LinkedIn Ads (Conversion API)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok Events API
TIKTOK_ACCESS_TOKEN=

# ====================
# INTEGRAÇÕES — CRMs
# ====================
# RD Station
RD_STATION_CLIENT_ID=
RD_STATION_CLIENT_SECRET=

# HubSpot
HUBSPOT_APP_ID=
HUBSPOT_CLIENT_SECRET=

# Pipedrive
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=

# ====================
# CORS & FRONTEND
# ====================
CORS_ORIGIN=https://ads.orffia.com
NEXT_PUBLIC_API_URL=https://api-ads.orffia.com

# ====================
# RATE LIMITING
# ====================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# ====================
# DOMÍNIOS (Traefik)
# ====================
DOMAIN_WEB=ads.orffia.com
DOMAIN_API=api-ads.orffia.com

# ====================
# CHECKLIST ANTES DE DEPLOY
# ====================
# [ ] Criar banco: CREATE DATABASE orffia_ads;
# [ ] Rodar migration: apps/api/src/db/migrations/0001_ads_schema.sql
# [ ] Trocar TODOS os secrets marcados com GERE/TROQUE
# [ ] Configurar DNS: ads.orffia.com e api-ads.orffia.com → 31.97.245.90
# [ ] Abrir portas 4002 e 4003 no firewall da VPS (ou usar Traefik)
# ====================

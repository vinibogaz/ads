# ==============================================
# Orffia Ads — Variáveis de Ambiente
# ==============================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores abaixo
# 3. NUNCA commite .env no git (já está no .gitignore)
# ==============================================

# ====================
# AMBIENTE
# ====================
# Ambiente de execução: development | production
NODE_ENV=production

# Porta da API (DEV: 3001, PROD VPS: 4000 para não conflitar com movAds)
PORT=4000

# Nível de log: error | warn | info | debug
LOG_LEVEL=info

# ====================
# DATABASE — PostgreSQL 15 + pgvector
# ====================
# IMPORTANTE: No VPS, usar PostgreSQL 15 existente (porta 5432, user: evolution)
# Antes de iniciar, rodar: infra/scripts/init-database.sql
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/DATABASE
# DEV: postgresql://evolution:evolution123@localhost:5432/orffia
# PROD: postgresql://evolution:evolution123@172.17.0.1:5432/orffia
DATABASE_URL=postgresql://evolution:evolution123@172.17.0.1:5432/orffia

# ====================
# REDIS
# ====================
# Redis para cache e sessões
# DEV: redis://localhost:6379
# PROD: redis://:SENHA@redis:6379/0 (interno ao Docker Compose)
REDIS_URL=redis://:SENHA_REDIS@redis:6379/0

# Senha do Redis (usado no docker-compose.prod.yml)
# Gerar: openssl rand -hex 16
REDIS_PASSWORD=TROQUE_ESTA_SENHA_REDIS

# ====================
# SEGURANÇA — JWT & CRIPTOGRAFIA
# ====================
# JWT Access Token Secret (min 32 chars)
# Gerar: openssl rand -hex 32
JWT_ACCESS_SECRET=GERE_COM_OPENSSL_RAND_HEX_32_SUBSTITUA_ESTE_VALOR_AQUI_URGENTE

# JWT Refresh Token Secret (min 32 chars, DIFERENTE do access)
# Gerar: openssl rand -hex 32
JWT_REFRESH_SECRET=GERE_COM_OPENSSL_RAND_HEX_32_OUTRO_VALOR_DIFERENTE_DO_ACCESS

# Chave de criptografia para credenciais de CMS (exatamente 64 hex chars = 32 bytes)
# Gerar: openssl rand -hex 32
ENCRYPTION_KEY=GERE_COM_OPENSSL_RAND_HEX_32_PRODUZ_64_CARACTERES_HEX_00000000

# ====================
# AI WORKER
# ====================
# URL do AI Worker (Python FastAPI)
# DEV: http://localhost:8000
# PROD: http://ai-worker:8000 (interno ao Docker Compose)
AI_WORKER_URL=http://ai-worker:8000

# Secret compartilhado entre API e AI Worker
# Gerar: openssl rand -hex 16
AI_WORKER_SECRET=GERE_COM_OPENSSL_RAND_HEX_16

# ====================
# APIS EXTERNAS — AI
# ====================
# OpenAI API Key (GPT-4o para geração de conteúdo)
# Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic API Key (Claude 3.5 Sonnet para fallback)
# Obter em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# Google AI API Key (Gemini 2.0 Flash para GEO Monitor)
# Obter em: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Perplexity API Key (Sonar para GEO Monitor)
# Obter em: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ====================
# CORS
# ====================
# Origem permitida para CORS (frontend)
# DEV: http://localhost:3000
# PROD: https://app.seudominio.com
CORS_ORIGIN=https://orffia.com

# ====================
# FRONTEND — Next.js
# ====================
# URL pública da API (usada pelo navegador)
# DEV: http://localhost:3001
# PROD: https://api.orffia.com
NEXT_PUBLIC_API_URL=https://api.orffia.com

# ====================
# RATE LIMITING
# ====================
# Máximo de requests por janela de tempo
RATE_LIMIT_MAX=100

# Janela de tempo (formato: "1 minute", "15 minutes", "1 hour")
RATE_LIMIT_WINDOW=1 minute

# ====================
# CHECKLIST ANTES DE DEPLOY
# ====================
# [ ] Trocar TODAS as senhas/secrets marcadas com TROQUE/GERE
# [ ] Rodar infra/scripts/init-database.sql no PostgreSQL
# [ ] Configurar DNS apontando para o VPS (31.97.245.90)
# [ ]   A record: orffia.com → 31.97.245.90
# [ ]   A record: api.orffia.com → 31.97.245.90
# [ ] Gerar certificado SSL via Traefik (Let's Encrypt) ou: sudo certbot --nginx -d orffia.com -d api.orffia.com
# [ ] Revisar CORS_ORIGIN (https://orffia.com) e NEXT_PUBLIC_API_URL (https://api.orffia.com)
# [ ] Testar conexão com PostgreSQL: psql $DATABASE_URL
# ====================
